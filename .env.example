# Copy this file to .env and fill in your own values.

# Required for the "Generate narrative" step.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional. Defaults to claude-sonnet-5 if not set.
CLAUDE_MODEL=claude-sonnet-5

# Optional. Defaults to 3000.
PORT=3000

# Required for the "Connect QuickBooks" step.
# Register an app (free) at https://developer.intuit.com/app/developer/myapps
# and copy its sandbox Client ID / Client Secret here.
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=

# Must exactly match a redirect URI listed on your Intuit app.
QBO_REDIRECT_URI=http://localhost:3000/api/quickbooks/callback

# sandbox or production. Use sandbox until you're ready to go live —
# production requires Intuit app review.
QBO_ENVIRONMENT=sandbox

# Only needed for "Download PDF" if the app can't auto-detect your browser.
# Point this at your Chrome/Chromium/Edge executable, e.g. on macOS:
# /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
PUPPETEER_EXECUTABLE_PATH=

# Only needed if deploying somewhere with an ephemeral filesystem (see
# README's Deployment section) — points the OAuth token file at a mounted
# persistent disk instead of the app's own folder.
QBO_TOKEN_FILE=

# Leave both blank for local use. REQUIRED before deploying anywhere with a
# public URL — without these, anyone who finds the URL can see a connected
# company's financial data. Any username/password works; make up your own.
BASIC_AUTH_USER=
BASIC_AUTH_PASS=
